{
  "name": "rego-agent",
  "version": "0.1.0",
  "private": true,
  "description": "스파르타 AI 에이전트 스터디 플랫폼",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "format": "prettier --write .",
    "setup": "tsx scripts/setup.ts",
    "agents:create": "tsx scripts/bulk-create-agents.ts",
    "seed": "tsx scripts/seed-demo.ts",
    "db:push": "pnpm --filter @rego/runtime db:push",
    "db:studio": "pnpm --filter @rego/runtime db:studio",
    "check:codeowners": "tsx scripts/check-codeowners.ts",
    "check:secrets": "tsx scripts/check-secrets.ts",
    "manifest:sync": "tsx scripts/manifest-sync.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "@rego/runtime-sdk": "workspace:*",
    "@rego/tools": "workspace:*"
  }
}
