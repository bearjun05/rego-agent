# ─────────────────────────────────────────────────────────
# rego-agent dashboard — Railway 배포 (Next.js 14)
# ─────────────────────────────────────────────────────────
FROM node:20-slim AS base
RUN corepack enable && corepack prepare pnpm@10.32.1 --activate
WORKDIR /app

# ── deps ──
FROM base AS deps
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc turbo.json ./
COPY apps/runtime/package.json ./apps/runtime/
COPY apps/dashboard/package.json ./apps/dashboard/
COPY packages/runtime-sdk/package.json ./packages/runtime-sdk/
COPY packages/tools/package.json ./packages/tools/
COPY packages/db/package.json ./packages/db/
COPY agents/_template/package.json ./agents/_template/
RUN pnpm install --frozen-lockfile --prefer-offline

# ── build: next build ──
# next.config.mjs의 rewrites()는 빌드 시점에 평가되므로 RUNTIME_URL을
# build ARG로 받아 프록시 대상이 정확히 구워지게 함.
# (Railway는 서비스 변수를 빌드 ARG로 전달 — dashboard 서비스에 RUNTIME_URL 설정 필요)
FROM deps AS build
ARG RUNTIME_URL
ENV RUNTIME_URL=${RUNTIME_URL}
ENV NEXT_TELEMETRY_DISABLED=1
COPY . .
RUN pnpm --filter @rego/dashboard build

# ── runtime: next start ──
FROM base AS runtime
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=build /app /app
# Railway가 PORT 주입. next start는 0.0.0.0 바인딩(공개 트래픽 수신).
CMD ["sh", "-c", "pnpm --filter @rego/dashboard exec next start -p ${PORT:-3000}"]
