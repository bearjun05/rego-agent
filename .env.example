# Slack
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_ID=

# Telegram
TELEGRAM_BOT_TOKEN=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# GitHub (webhooks)
GITHUB_WEBHOOK_SECRET=

# Database (Railway 자동 주입)
DATABASE_URL=postgresql://user:pass@host:5432/rego

# Admin (대시보드 보호)
ADMIN_PASSWORD=

# Models (OpenRouter 표기)
MODEL_CLASSIFY=anthropic/claude-haiku-4.5
MODEL_GENERATE=anthropic/claude-sonnet-4.5
MODEL_CHAT=anthropic/claude-sonnet-4.5

# Runtime
RUNTIME_PORT=3001
DASHBOARD_PORT=3000
PUBLIC_BASE_URL=http://localhost:3001
DASHBOARD_BASE_URL=http://localhost:3000

# Limits
RUN_TIMEOUT_MS=30000
RUN_MAX_LLM_CALLS=10
RUN_MAX_TOOL_CALLS=20
RUNAWAY_CALLS_PER_MIN=200
RUNAWAY_LLM_PER_MIN=100
