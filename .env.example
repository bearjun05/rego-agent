# ─────────────────────────────────────────────────────────
# Slack
# ─────────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_ID=
# 봇 자신의 user id(U…) — 선택. self-message 무시용(bot_id 필터가 1차 방어).
SLACK_BOT_USER_ID=
# 감시할 채널 allowlist (쉼표구분, 채널ID C… 또는 채널명). 비우면 전체 채널 감지.
# 예: SLACK_MONITOR_CHANNELS=C0123ABCD,우리팀_잡담
SLACK_MONITOR_CHANNELS=

# ─────────────────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─────────────────────────────────────────────────────────
# OpenRouter (LLM)
# ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─────────────────────────────────────────────────────────
# GitHub (folder-violation 경고 / 자체서버 핫리로드 webhook)
# ─────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────
# Database
# 로컬: docker-compose의 postgres. Railway: Postgres 플러그인이 자동 주입
#   → Railway 변수에 DATABASE_URL=${{Postgres.DATABASE_URL}} (reference) 설정
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://rego:rego_local_password@localhost:5436/rego_agent

# ─────────────────────────────────────────────────────────
# Admin (대시보드 보호)
# ─────────────────────────────────────────────────────────
ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────
# Models (OpenRouter 슬러그) — deepseek 사용
# ─────────────────────────────────────────────────────────
MODEL_CLASSIFY=deepseek/deepseek-v4-flash
MODEL_GENERATE=deepseek/deepseek-v4-flash
MODEL_CHAT=deepseek/deepseek-v4-flash

# ─────────────────────────────────────────────────────────
# Runtime / 네트워크
# - PORT: Railway가 동적 주입(설정 불필요). 미설정 시 RUNTIME_PORT 사용.
# - BIND_HOST: 미설정 시 Railway면 '::'(IPv6 듀얼스택), 그 외 0.0.0.0.
# - SELF_HOSTED_IPV4_ONLY: 자체 우분투 서버(IPv6 경로 없음)에서만 '1'.
#     Railway에선 절대 설정 금지(사설망 *.railway.internal 깨짐).
# - RUNTIME_URL: dashboard → runtime 프록시 대상.
#     Railway 사설망: http://${{runtime.RAILWAY_PRIVATE_DOMAIN}}:${{runtime.PORT}}
#     (안 되면 폴백으로 runtime 공개 https 도메인)
# ─────────────────────────────────────────────────────────
RUNTIME_PORT=3001
DASHBOARD_PORT=3000
PUBLIC_BASE_URL=http://localhost:3001
DASHBOARD_BASE_URL=http://localhost:3000
RUNTIME_URL=http://localhost:3001
# BIND_HOST=
# SELF_HOSTED_IPV4_ONLY=1

# ─────────────────────────────────────────────────────────
# Limits (무한루프 방지 — 분당 한도 초과 시 자동 정지)
# ─────────────────────────────────────────────────────────
RUN_TIMEOUT_MS=30000
RUN_MAX_LLM_CALLS=10
RUN_MAX_TOOL_CALLS=20
RUNAWAY_CALLS_PER_MIN=200
RUNAWAY_LLM_PER_MIN=100
