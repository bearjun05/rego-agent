# rego-agent 환경변수 (op:// 참조 — git commit 안전)
#
# 이 파일은 1Password Service Account 토큰으로 실제 값을 가져와서 주입합니다.
# 평문 값은 mini-server vault 항목에만 존재합니다.
#
# 시작: ./scripts/start.sh
# 또는: op run --env-file=.env.1p -- <command>
#
# 항목 추가가 필요한 경우 1Password 앱/웹에서 직접 (서비스 계정으로는 create 불가).

# ── Database (로컬 Docker, 평문 OK) ─────────────────────
DATABASE_URL=postgresql://rego:rego_local_password@localhost:5436/rego_agent

# ── Runtime config ──────────────────────────────────────
NODE_ENV=production
RUNTIME_PORT=3001
DASHBOARD_PORT=3030
PUBLIC_BASE_URL=https://rego.jotto.in
DASHBOARD_BASE_URL=https://rego.jotto.in
RUNTIME_URL=http://localhost:3001

# ── Models ──────────────────────────────────────────────
MODEL_CLASSIFY=deepseek/deepseek-v4-flash
MODEL_GENERATE=deepseek/deepseek-v4-flash
MODEL_CHAT=deepseek/deepseek-v4-flash

# ── Limits ──────────────────────────────────────────────
RUN_TIMEOUT_MS=30000
RUN_MAX_LLM_CALLS=10
RUN_MAX_TOOL_CALLS=20
RUNAWAY_CALLS_PER_MIN=200
RUNAWAY_LLM_PER_MIN=100

# ── Secrets (1Password 참조) ────────────────────────────
SLACK_SIGNING_SECRET=op://mini-server/RegoAgent Slack Signing Secret/password
SLACK_BOT_TOKEN=op://mini-server/RegoAgent Slack Bot Token/password
TELEGRAM_BOT_TOKEN=op://mini-server/RegoAgent Telegram Bot Token/password
OPENROUTER_API_KEY=op://mini-server/RegoAgent OpenRouter API Key/password
GITHUB_WEBHOOK_SECRET=op://mini-server/RegoAgent GitHub Webhook Secret/password
ADMIN_PASSWORD=op://mini-server/RegoAgent Admin Password/password
NODE_OPTIONS=--dns-result-order=ipv4first
