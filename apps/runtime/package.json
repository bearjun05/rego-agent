{
  "name": "@rego/runtime",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:push": "drizzle-kit push --config ../../packages/db/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config ../../packages/db/drizzle.config.ts"
  },
  "dependencies": {
    "@rego/runtime-sdk": "workspace:*",
    "@rego/tools": "workspace:*",
    "@rego/db": "workspace:*",
    "hono": "^4.6.16",
    "@hono/node-server": "^1.13.7",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
